# Auth
CORTEX_PASSWORD=changeme
CORTEX_JWT_SECRET=change-this-to-a-random-32-char-string

# Ollama
OLLAMA_URL=http://localhost:11434

# Models (defaults, all changeable in Settings UI)
CORTEX_DEFAULT_MAIN_MODEL=gpt-oss:20b
CORTEX_DEFAULT_VISION_MODEL=qwen2.5-vl:7b
CORTEX_DEFAULT_EMBEDDING_MODEL=nomic-embed-text

# Memory
CORTEX_MEMORY_INTERVAL_MS=300000
CORTEX_MEMORY_RETRIEVAL_COUNT=10
CORTEX_DAILY_LOG_TIME=23:59

# Exports
CORTEX_EXPORT_DIR=./exports

# Notifications
CORTEX_NTFY_URL=https://ntfy.sh
CORTEX_NTFY_TOPIC=

# Database
CORTEX_DB_PATH=./cortex.db

# Server
PORT=3000
